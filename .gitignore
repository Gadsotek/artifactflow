# Private working docs only (audit notes, handoff, task/spec docs). Everything
# else under docs/ -- ARCHITECTURE, OPERATIONS, the architecture diagrams -- is
# public and published.
/docs/internal

# Private AI/agent working files at the repo root. These must never be tracked.
# Note: agent tooling may also snapshot them into checkpoint refs (for example
# refs/codex/turn-diffs/...), which .gitignore cannot cover -- see the
# "Before Publishing the Repository" section in RELEASE-CHECKLIST.md.
/HANDOFF.md
/SECURITY-AUDIT*.md
/_img.php

.claude/settings.local.json
.claude/*.local.json
.claude/projects/
.claude/logs/
.claude/todos/
.codex/*.local.toml
.codex/auth.json
.codex/history.jsonl
