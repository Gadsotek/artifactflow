{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "artifactflow",
  "description": "Self-hosted vault for safely storing, searching, versioning, and previewing AI-generated HTML artifacts.",
  "homepage": "https://artifactflow.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/Gadsotek/artifactflow.git"
  },
  "bugs": {
    "url": "https://github.com/Gadsotek/artifactflow/issues"
  },
  "keywords": [
    "artifactflow",
    "laravel",
    "html-artifacts"
  ],
  "author": "Gadsotek <gadsotek@gmail.com>",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=26"
  },
  "overrides": {
    "dompurify": "3.4.11",
    "shell-quote": "1.10.0"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-markdown": "^6.5.1",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@lezer/highlight": "^1.2.3",
    "codemirror": "^6.0.2",
    "laravel-echo": "^2.4.0",
    "mermaid": "11.16.0",
    "pusher-js": "^8.5.0"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "lint:js": "eslint resources/js eslint.config.js vite.config.js",
    "format": "prettier --write \"resources/js/**/*.js\"",
    "format:check": "prettier --check \"resources/js/**/*.js\"",
    "e2e": "playwright test",
    "e2e:debug": "playwright test --debug",
    "e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "laravel-vite-plugin": "^3.1.3",
    "prettier": "^3.9.6",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.5"
  }
}
