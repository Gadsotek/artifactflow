{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/scripts/ai-hooks/guard_prompt.py\" --agent codex",
            "timeout": 5,
            "statusMessage": "Scanning prompt for secrets"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/scripts/ai-hooks/guard_command.py\" --agent codex",
            "timeout": 10,
            "statusMessage": "Checking command safety"
          }
        ]
      },
      {
        "matcher": "^(Edit|Write|Read|Grep|Glob|apply_patch)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/scripts/ai-hooks/guard_file_write.py\" --agent codex",
            "timeout": 10,
            "statusMessage": "Checking file write safety"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/scripts/ai-hooks/guard_command.py\" --agent codex --event PermissionRequest",
            "timeout": 10,
            "statusMessage": "Checking approval request"
          }
        ]
      }
    ]
  }
}
