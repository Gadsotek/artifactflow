APP_NAME=artifactflow
APP_ENV=production
APP_KEY=base64:replace-with-a-generated-production-key
APP_DEBUG=false
APP_URL=https://app.example.internal
APP_SOURCE_URL=https://github.com/Gadsotek/artifactflow
ARTIFACT_URL=https://artifacts.example.internal
ARTIFACT_FRAME_ANCESTORS=https://app.example.internal
# HTTP Strict-Transport-Security (sent on every response; browsers ignore it over
# plain HTTP). A strong two-year max-age is always on. includeSubDomains and preload
# are OFF by default because they reach beyond this host and are hard to undo: only
# set HSTS_INCLUDE_SUBDOMAINS=true once every subdomain under this host serves HTTPS,
# and HSTS_PRELOAD=true only if you own the whole parent domain and intend to submit
# it to the browser preload list (a near-permanent commitment).
HSTS_MAX_AGE=63072000
HSTS_INCLUDE_SUBDOMAINS=false
HSTS_PRELOAD=false
ARTIFACT_URL_SIGNING_KEY=base64:replace-with-a-generated-artifact-signing-key
ARTIFACT_PREVIEW_URL_TTL_SECONDS=60
ARTIFACT_MAX_BYTES=10485760
ARTIFACT_DRAFT_PREVIEW_MAX_BODY=6MB
PAGE_WORKSPACE_MAX_STORAGE_BYTES=1073741824
PAGE_MAX_PAGE_STORAGE_BYTES=104857600
PAGE_MAX_PAGE_VERSIONS=200
PAGE_MAX_TAGS_PER_PAGE=25
WORKSPACE_INVITATION_TTL_DAYS=7
WORKSPACE_CREATES_PER_MINUTE=10
WORKSPACE_INVITATIONS_PER_MINUTE=10
WORKSPACE_INVITATION_ACCEPTS_PER_MINUTE=10
PASSWORD_RESETS_PER_HOUR=5
AUTH_PASSWORD_TIMEOUT=900
AUTH_ADMIN_PASSWORD_TIMEOUT=900
ADMIN_STEP_UP_RATE_LIMIT_PER_MINUTE=5
PAGE_PRESENCE_RATE_LIMIT_PER_MINUTE=120
MCP_PRE_AUTH_RATE_LIMIT_PER_MINUTE=300
MCP_RATE_LIMIT_PER_MINUTE=60
MCP_WRITE_RATE_LIMIT_PER_MINUTE=20
TWO_FACTOR_CHALLENGE_TIMEOUT_SECONDS=300
TWO_FACTOR_DRIFT_WINDOW=1
TWO_FACTOR_TRUSTED_DEVICE_DAYS=30
TWO_FACTOR_CHALLENGE_RATE_LIMIT_PER_MINUTE=5
TWO_FACTOR_CHALLENGE_ACCOUNT_RATE_LIMIT_PER_HOUR=30
TWO_FACTOR_CHALLENGE_IP_RATE_LIMIT_PER_MINUTE=20
APP_RUNTIME_ROLE=app
TRUSTED_PROXIES=REMOTE_ADDR
DEFAULT_THEME=system
ARTIFACTFLOW_ADMIN_PASSWORD=
ARTIFACTFLOW_CREATE_USER_PASSWORD=
ARTIFACTFLOW_RESET_PASSWORD=

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=postgres.example.internal
DB_PORT=5432
DB_DATABASE=artifactflow
DB_USERNAME=artifactflow_app
DB_PASSWORD=replace-with-a-strong-password
DB_SSLMODE=verify-full
DB_SSLROOTCERT=/etc/ssl/certs/ca-certificates.crt

BROADCAST_CONNECTION=null
REVERB_APP_ID=replace-with-reverb-app-id
REVERB_APP_KEY=replace-with-reverb-app-key
REVERB_APP_SECRET=replace-with-reverb-app-secret
REVERB_HOST=app.example.internal
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_PUBLIC_URL=https://app.example.internal
REVERB_ALLOWED_ORIGINS=https://app.example.internal
REVERB_APP_MAX_CONNECTIONS=1000
REVERB_APP_RATE_LIMITING_ENABLED=true
VITE_REVERB_APP_KEY=replace-with-reverb-app-key
VITE_REVERB_HOST=app.example.internal
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_DOMAIN=app.example.internal
SESSION_SECURE_COOKIE=true
SESSION_ENCRYPT=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# Configure a real transport before inviting users: MAIL_MAILER=resend (with
# RESEND_KEY) or MAIL_MAILER=smtp. The default 'log' only writes mail to the log.
MAIL_MAILER=log
RESEND_KEY=replace-with-resend-api-key
MAIL_FROM_ADDRESS=artifactflow@example.internal
MAIL_FROM_NAME=artifactflow

ARTIFACT_STORAGE_ROOT=/var/www/html/storage/app/private_artifacts
RUN_MIGRATIONS=0
