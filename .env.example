# LOCAL DEVELOPMENT ONLY. This file ships insecure defaults (debug enabled,
# plain-HTTP cookies, database TLS disabled) that the production boot guard
# rejects. For internet-facing deployments start from .env.production.example.
APP_NAME=artifactflow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:18080
APP_SOURCE_URL=https://github.com/Gadsotek/artifactflow
# The artifact host deliberately uses 127.0.0.1 while the app uses localhost:
# cookies ignore the port (RFC 6265), so the two origins must differ by HOST or
# the browser would attach the app session cookie to artifact requests.
ARTIFACT_URL=http://127.0.0.1:18081
ARTIFACT_FRAME_ANCESTORS=http://localhost:18080
ARTIFACT_URL_SIGNING_KEY=
ARTIFACT_PREVIEW_URL_TTL_SECONDS=60
DRAFT_PREVIEW_CAPABILITY_RATE_LIMIT_PER_MINUTE=30
ARTIFACT_MAX_BYTES=10485760
ARTIFACT_DRAFT_PREVIEW_MAX_BODY=6MB
PAGE_WORKSPACE_MAX_STORAGE_BYTES=1073741824
PAGE_MAX_PAGE_STORAGE_BYTES=104857600
PAGE_MAX_PAGE_VERSIONS=200
PAGE_MAX_TAGS_PER_PAGE=25
WORKSPACE_INVITATION_TTL_DAYS=7
WORKSPACE_CREATES_PER_MINUTE=10
WORKSPACE_INVITATIONS_PER_MINUTE=10
WORKSPACE_INVITATION_ACCEPTS_PER_MINUTE=10
PASSWORD_RESETS_PER_HOUR=5
AUTH_PASSWORD_TIMEOUT=900
AUTH_ADMIN_PASSWORD_TIMEOUT=900
ADMIN_STEP_UP_RATE_LIMIT_PER_MINUTE=5
PAGE_PRESENCE_RATE_LIMIT_PER_MINUTE=120
MCP_PRE_AUTH_RATE_LIMIT_PER_MINUTE=300
MCP_RATE_LIMIT_PER_MINUTE=60
MCP_WRITE_RATE_LIMIT_PER_MINUTE=20
TWO_FACTOR_CHALLENGE_TIMEOUT_SECONDS=300
TWO_FACTOR_DRIFT_WINDOW=1
TWO_FACTOR_TRUSTED_DEVICE_DAYS=30
TWO_FACTOR_CHALLENGE_RATE_LIMIT_PER_MINUTE=5
TWO_FACTOR_CHALLENGE_ACCOUNT_RATE_LIMIT_PER_HOUR=30
TWO_FACTOR_CHALLENGE_IP_RATE_LIMIT_PER_MINUTE=20
APP_RUNTIME_ROLE=app
TRUSTED_PROXIES=127.0.0.1,::1,172.16.0.0/12
DEFAULT_THEME=system
ARTIFACTFLOW_ADMIN_PASSWORD=
ARTIFACTFLOW_CREATE_USER_PASSWORD=
ARTIFACTFLOW_RESET_PASSWORD=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=artifactflow
DB_USERNAME=app_user
DB_PASSWORD=app_local_password
DB_SSLMODE=disable
DB_SSLROOTCERT=
DB_SUPERUSER=postgres
DB_SUPERPASS=postgres
DB_HOST_PORT=55440

TEST_DB_SERVICE=db-test
TEST_DB_HOST=db-test
TEST_DB_PORT=5432
TEST_DB_DATABASE=artifactflow_test
TEST_DB_USERNAME=app_user
TEST_DB_PASSWORD=app_local_password
TEST_DB_SUPERUSER=postgres
TEST_DB_SUPERPASS=postgres_test_password
TEST_DB_HOST_PORT=55442

BROADCAST_CONNECTION=null
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_PUBLIC_URL=http://localhost:8080
REVERB_ALLOWED_ORIGINS=http://localhost:18080
REVERB_APP_MAX_CONNECTIONS=1000
REVERB_APP_RATE_LIMITING_ENABLED=true
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
CACHE_STORE=file
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false
SESSION_ENCRYPT=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# Outbound mail. Default is the local 'log' transport so a fresh install boots
# without a third-party mail account; switch to smtp/resend for real delivery.
MAIL_MAILER=log
RESEND_KEY=
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=dev@artifactflow.local
MAIL_FROM_NAME=artifactflow

# Host ports for Docker port mappings; change freely if they collide with
# something on your machine. The ports are ALSO embedded in URLs above, so
# change them as a pair (`php artisan artifactflow:doctor` warns on a mismatch):
#   APP_PORT           <-> APP_URL, ARTIFACT_FRAME_ANCESTORS, REVERB_ALLOWED_ORIGINS
#   ARTIFACT_HOST_PORT <-> ARTIFACT_URL
APP_PORT=18080
ARTIFACT_HOST_PORT=18081
VITE_PORT=5181
ADMINER_PORT=18089
MAILPIT_SMTP_PORT=11033
MAILPIT_WEB_PORT=18033
EDGE_HTTP_PORT=18085

ARTIFACT_STORAGE_ROOT=/var/www/html/storage/app/private_artifacts
RUN_MIGRATIONS=0
INSTALL_XDEBUG=0
XDEBUG_MODE=off
XDEBUG_CLIENT_HOST=host.docker.internal
XDEBUG_CLIENT_PORT=9010
XDEBUG_IDEKEY=VSCODE
XDEBUG_START_WITH_REQUEST=trigger
